#!/usr/bin/env bash
# huginn — estate-management CLI. Manages the repos in $HUGINN_ROOT (default ~/github-repos).
# Odin's raven: flies the realms, reports back. Working name — alias/rename freely.
#
#   huginn status | sync | doctor | new | init | apply | conventions | prs | branches | open
#   run 'huginn help' for the menu, or 'huginn <command> help' for per-command detail.
set -uo pipefail
SELF="$(readlink -f "$0" 2>/dev/null || echo "$0")"; HERE="$(cd "$(dirname "$SELF")" && pwd)"
# ── configuration — env  >  config file  >  smart defaults ────────────────
CONFIG="${HUGINN_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/huginn/config}"
for _v in OWNER EMAIL NAME ROOT FAMILY CONVENTIONS; do eval "_env_$_v=\${HUGINN_$_v-}"; done
[ -f "$CONFIG" ] && . "$CONFIG"
ROOT="${_env_ROOT:-${HUGINN_ROOT:-$HOME/github-repos}}"
OWNER="${_env_OWNER:-${HUGINN_OWNER:-}}"                       # resolved lazily — see need_owner
BIZ_EMAIL="${_env_EMAIL:-${HUGINN_EMAIL:-$(git config user.email 2>/dev/null)}}"
BIZ_NAME="${_env_NAME:-${HUGINN_NAME:-$(git config user.name 2>/dev/null)}}"
FAMILY="${_env_FAMILY:-${HUGINN_FAMILY:-}}"                    # space-separated repos to exclude
CONV="$ROOT/${_env_CONVENTIONS:-${HUGINN_CONVENTIONS:-repo-conventions}}"

if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  R=$'\e[31m'; G=$'\e[32m'; Y=$'\e[33m'; C=$'\e[36m'; M=$'\e[35m'; DIM=$'\e[2m'; BD=$'\e[1m'; X=$'\e[0m'
else R=; G=; Y=; C=; M=; DIM=; BD=; X=; fi

is_exempt(){ case " $FAMILY $CONV_EXEMPT " in *" $1 "*) return 0;; *) return 1;; esac; }  # HUGINN_FAMILY env + conventions exemptions.json
is_help(){ case "${1:-}" in help|-h|--help) return 0;; *) return 1;; esac; }
repos(){ (cd "$ROOT" && for d in */; do [ -d "${d}.git" ] && echo "${d%/}"; done | sort); }
need_owner(){ [ -n "$OWNER" ] && return 0; OWNER="$(gh api user --jq .login 2>/dev/null)"; [ -n "$OWNER" ] && return 0; printf "  ${R}no GitHub owner set.${X} Set HUGINN_OWNER, add it to %s, or run ${BD}huginn init${X}.\n" "$CONFIG" >&2; return 1; }
first_of(){ local f; for f in "$@"; do [ -e "$f" ] && { printf '%s' "$f"; return 0; }; done; return 1; }  # your conventions repo, else bundled templates
# exempt repos from the conventions data (merged with HUGINN_FAMILY by is_exempt)
CONV_EXEMPT=""; _ej="$(first_of "$CONV/exemptions.json" "$HERE/templates/exemptions.json")"
[ -n "$_ej" ] && CONV_EXEMPT="$(jq -r '.exempt[].repo' "$_ej" 2>/dev/null | tr '\n' ' ')"

# ── status ────────────────────────────────────────────────────────────────
cmd_status(){
  is_help "${1:-}" && { help_status; return 0; }
  case " $* " in *" --public "*|*" --private "*|*" --pub "*|*" --priv "*) need_owner || return 1;; esac  # visibility filter needs the owner
  HUGINN_ROOT="$ROOT" HUGINN_EMAIL="$BIZ_EMAIL" HUGINN_OWNER="$OWNER" exec "$HERE/repo-status.sh" "$@"
}

# ── sync ──────────────────────────────────────────────────────────────────
cmd_sync(){
  is_help "${1:-}" && { help_sync; return 0; }
  local ok=0 skip=0 prob=0 def
  printf "\n  ${BD}huginn sync${X}  ${DIM}· pull each repo to its default branch${X}\n\n"
  while read -r d; do
    if is_exempt "$d"; then printf "  ${DIM}∙ %s (external)${X}\n" "$d"; skip=$((skip+1)); continue; fi
    local GD="$ROOT/$d"
    if [ -n "$(git -C "$GD" status --porcelain 2>/dev/null)" ]; then printf "  ${Y}∙ %s (dirty — skipped)${X}\n" "$d"; skip=$((skip+1)); continue; fi
    def=$(git -C "$GD" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##'); def=${def:-main}
    git -C "$GD" checkout -q "$def" 2>/dev/null
    if git -C "$GD" pull -q --ff-only origin "$def" 2>/dev/null; then printf "  ${G}✓${X} %-32s ${DIM}(%s)${X}\n" "$d" "$def"; ok=$((ok+1))
    else printf "  ${R}✗ %s (couldn't fast-forward)${X}\n" "$d"; prob=$((prob+1)); fi
  done < <(repos)
  printf "\n  ${BD}%d updated${X} ${DIM}·${X} ${Y}%d skipped${X} ${DIM}·${X} ${R}%d problems${X}\n\n" "$ok" "$skip" "$prob"
}

# ── doctor ────────────────────────────────────────────────────────────────
cmd_doctor(){
  is_help "${1:-}" && { help_doctor; return 0; }
  need_owner || return 1
  local FIX=0 target="" verbose=0
  for a in "$@"; do case "$a" in
    --fix) FIX=1;; -v|--verbose) verbose=1;; -*) ;; *) target="$a";; esac; done

  printf "\n  ${BD}huginn doctor${X}  ${DIM}· audit vs conventions%s · %s${X}\n" \
    "$([ "$FIX" = 1 ] && echo ' · FIX mode')" "$(date '+%H:%M')"
  printf "  ${DIM}(network — checks rulesets + security settings per repo)${X}\n\n"

  local ok=0 gap=0 dormant=0 fixed=0
  local dsj reqdocs=""; dsj="$(first_of "$CONV/docs-suite.json" "$HERE/templates/docs-suite.json")"
  [ -n "$dsj" ] && reqdocs="$(jq -r '.required[].file' "$dsj" 2>/dev/null)"
  while read -r d; do
    [ -n "$target" ] && [ "$d" != "$target" ] && continue
    is_exempt "$d" && continue
    local GD="$ROOT/$d"; local -a issues=()

    # baseline: business email
    local email; email=$(git -C "$GD" config --local user.email 2>/dev/null)
    if [ "$email" != "$BIZ_EMAIL" ]; then
      if [ "$FIX" = 1 ]; then
        git -C "$GD" config user.email "$BIZ_EMAIL"; git -C "$GD" config user.name "$BIZ_NAME"
        issues+=("${G}✚email${X}"); fixed=$((fixed+1))
      else issues+=("${Y}local-email${X}"); fi
    fi
    # baseline: ruleset present
    local rid; rid=$(gh api "repos/$OWNER/$d/rulesets" --jq '.[]|select(.name=="require-pr-to-default")|.id' 2>/dev/null | head -1)
    [ -z "$rid" ] && issues+=("${R}no-ruleset${X}")

    if [ -f "$GD/.github/workflows/agentgate.yml" ]; then
      # managed repo — full standard
      local rtypes=""; [ -n "$rid" ] && rtypes=$(gh api "repos/$OWNER/$d/rulesets/$rid" --jq '[.rules[].type]|join(" ")' 2>/dev/null)
      if [ -z "$rid" ] || [[ "$rtypes" != *required_status_checks* ]] || [[ "$rtypes" != *required_signatures* ]]; then
        local rsj; rsj="$(first_of "$CONV/ruleset.json" "$HERE/templates/ruleset.json")"
        if [ "$FIX" = 1 ] && [ -n "$rsj" ]; then
          if [ -n "$rid" ]; then gh api -X PUT "repos/$OWNER/$d/rulesets/$rid" --input "$rsj" >/dev/null 2>&1
          else gh api -X POST "repos/$OWNER/$d/rulesets" --input "$rsj" >/dev/null 2>&1; fi
          issues+=("${G}✚ruleset${X}"); fixed=$((fixed+1))
        else
          [[ "$rtypes" != *required_status_checks* ]] && issues+=("${Y}gate-not-required${X}")
          [[ "$rtypes" != *required_signatures* ]]    && issues+=("${Y}sign-not-required${X}")
        fi
      fi
      [ -f "$GD/.agentgate.yml" ] || issues+=("${Y}no-.agentgate.yml${X}")
      local vis="" ss="" defb=""
      read -r vis ss defb < <(gh api "repos/$OWNER/$d" --jq '"\(.visibility) \(.security_and_analysis.secret_scanning.status // "na") \(.default_branch)"' 2>/dev/null || echo "? ? main")
      [ "$vis" = public ] && [ "$ss" != enabled ] && issues+=("${Y}secret-scan-off${X}")
      # legacy classic branch protection — estate standard is rulesets, not classic protection
      [ -n "$defb" ] && gh api "repos/$OWNER/$d/branches/$defb/protection" >/dev/null 2>&1 && issues+=("${Y}classic-protection${X}")
      if [ -n "$reqdocs" ]; then
        local miss="" df; for df in $reqdocs; do [ -f "$GD/$df" ] || miss="${miss},${df%.md}"; done
        [ -n "$miss" ] && issues+=("${Y}docs:${miss#,}${X}")
      fi

      if [ ${#issues[@]} -eq 0 ]; then ok=$((ok+1)); [ "$verbose" = 1 ] && printf "  ${G}✓${X} %s\n" "$d"
      else gap=$((gap+1)); printf "  ${Y}▲${X} ${BD}%-32s${X} %s\n" "$d" "${issues[*]}"; fi
    else
      # dormant / unwired — baseline only
      dormant=$((dormant+1))
      [ ${#issues[@]} -gt 0 ] && printf "  ${DIM}∙ %-32s %s (dormant)${X}\n" "$d" "${issues[*]}"
    fi
  done < <(repos)

  printf "\n  ${G}%d managed & compliant${X} ${DIM}·${X} ${Y}%d with gaps${X} ${DIM}·${X} ${DIM}%d dormant${X}" "$ok" "$gap" "$dormant"
  [ "$FIX" = 1 ] && printf " ${DIM}·${X} ${G}%d fixed${X}" "$fixed"
  [ "$FIX" = 0 ] && [ "$gap" -gt 0 ] && printf "\n  ${DIM}run 'huginn doctor --fix' to auto-fix local-email gaps; other gaps → 'huginn conventions'${X}"
  printf "\n\n"
}

# ── apply ─────────────────────────────────────────────────────────────────
cmd_apply(){ is_help "${1:-}" && { help_apply; return 0; }; local a; a="$(first_of "$CONV/apply-conventions.sh" "$HERE/templates/apply-conventions.sh")"; [ -n "$a" ] || { printf "  ${R}no apply-conventions.sh found${X}\n"; return 1; }; exec "$a" "$@"; }

# ── conventions (look up the standard) ────────────────────────────────────
cmd_conventions(){
  is_help "${1:-}" && { help_conventions; return 0; }
  local RC="$CONV" LJ RJ DSJ
  LJ="$(first_of "$RC/labels.json" "$HERE/templates/labels.json")"
  RJ="$(first_of "$RC/ruleset.json" "$HERE/templates/ruleset.json")"
  DSJ="$(first_of "$RC/docs-suite.json" "$HERE/templates/docs-suite.json")"
  case "${1:-overview}" in
    labels)
      [ -n "$LJ" ] || { printf "\n  ${R}no labels.json found${X}\n\n"; return 1; }
      printf "\n  ${BD}Label taxonomy${X}  ${DIM}· %s${X}\n" "$LJ"
      local groups; if [ -n "${2:-}" ]; then groups="$2"; else groups=$(jq -r 'keys[]' "$LJ"); fi
      for g in $groups; do
        jq -e --arg g "$g" 'has($g)' "$LJ" >/dev/null 2>&1 || { printf "\n  ${Y}no such group: %s  (have: %s)${X}\n" "$g" "$(jq -r 'keys|join(", ")' "$LJ")"; continue; }
        printf "\n  ${BD}%s${X}\n" "$g"
        while IFS=$'\t' read -r color name desc; do
          if [ -n "$X" ]; then
            local rr=$((16#${color:0:2})) gg=$((16#${color:2:2})) bb=$((16#${color:4:2}))
            printf "    \033[48;2;%d;%d;%dm  \033[0m \033[38;2;%d;%d;%dm%-15s\033[0m ${DIM}%s${X}\n" "$rr" "$gg" "$bb" "$rr" "$gg" "$bb" "$name" "$desc"
          else
            printf "    %-15s  %s  #%s\n" "$name" "$desc" "$color"
          fi
        done < <(jq -r --arg g "$g" '.[$g][] | "\(.color)\t\(.name)\t\(.description)"' "$LJ")
      done
      printf "\n  ${DIM}apply with:  huginn apply <owner/repo> <web|k8s|infra>   (adds base + that scope)${X}\n\n"
      ;;
    ruleset)
      [ -n "$RJ" ] || { printf "\n  ${R}no ruleset.json found${X}\n\n"; return 1; }
      printf "\n  ${BD}Branch-protection ruleset${X}  ${DIM}· '%s'${X}\n\n" "$(jq -r .name "$RJ")"
      while read -r t; do case "$t" in
        pull_request)           printf "    ${G}✓${X} changes reach the default branch only via a pull request ${DIM}(0 approvals — solo)${X}\n";;
        required_status_checks) printf "    ${G}✓${X} the ${BD}agentgate${X} check must pass before merge\n";;
        required_signatures)    printf "    ${G}✓${X} every commit must be signed & Verified\n";;
        non_fast_forward)       printf "    ${G}✓${X} no force-pushes to the default branch\n";;
        deletion)               printf "    ${G}✓${X} the default branch can't be deleted\n";;
        *)                      printf "    ${G}✓${X} %s\n" "$t";;
      esac; done < <(jq -r '.rules[].type' "$RJ")
      printf "    ${DIM}↳ admin can bypass in an emergency; targets ~DEFAULT_BRANCH${X}\n\n"
      ;;
    suite|docs)
      [ -n "$DSJ" ] || { printf "\n  ${R}no docs-suite.json found${X}\n\n"; return 1; }
      printf "\n  ${BD}Document suite${X}  ${DIM}· %s${X}\n\n" "$DSJ"
      printf "  ${BD}Required${X} ${DIM}· every repo — doctor verifies, new scaffolds${X}\n"
      while IFS=$'\t' read -r f p; do printf "    ${G}✓${X} %-16s ${DIM}%s${X}\n" "$f" "$p"; done < <(jq -r '.required[]|"\(.file)\t\(.purpose)"' "$DSJ")
      printf "\n  ${BD}Recommended${X} ${DIM}· when it applies${X}\n"
      while IFS=$'\t' read -r f w p; do printf "    ${Y}+${X} %-16s ${DIM}%s  (%s)${X}\n" "$f" "$p" "$w"; done < <(jq -r '.recommended[]|"\(.file)\t\(.when)\t\(.purpose)"' "$DSJ")
      printf "\n"
      ;;
    doc|md)
      if [ -f "$RC/CONVENTIONS.md" ]; then
        if [ -t 1 ] && command -v less >/dev/null 2>&1; then less -R "$RC/CONVENTIONS.md"; else cat "$RC/CONVENTIONS.md"; fi
      else printf "\n  ${Y}no CONVENTIONS.md${X} ${DIM}(point HUGINN_CONVENTIONS at a repo that has one)${X}\n\n"; fi
      ;;
    *)
      printf "\n  ${BD}conventions${X}  ${DIM}· source: %s${X}\n\n" "$([ -d "$RC" ] && echo "$RC" || echo "bundled templates")"
      printf "  ${BD}huginn conventions labels${X} [scope]   label taxonomy (base + web/k8s/infra), in real colors\n"
      printf "  ${BD}huginn conventions ruleset${X}          the branch-protection rules, in plain English\n"
      printf "  ${BD}huginn conventions suite${X}            the required document suite\n"
      printf "  ${BD}huginn conventions doc${X}              the full CONVENTIONS.md\n\n"
      ;;
  esac
}

# ── prs (open PRs across the estate) ──────────────────────────────────────
cmd_prs(){
  is_help "${1:-}" && { help_prs; return 0; }
  need_owner || return 1
  printf "\n  ${BD}open PRs across the estate${X}  ${DIM}· %s${X}\n\n" "$(date '+%H:%M')"
  local rows; rows=$(gh search prs --owner "$OWNER" --state open --limit 100 \
    --json repository,number,title,author --jq '.[] | [.repository.name,(.number|tostring),.title,.author.login] | @tsv' 2>/dev/null)
  local n=0
  while IFS=$'\t' read -r repo num title author; do
    [ -z "$repo" ] && continue; is_exempt "$repo" && continue
    printf "  ${C}%-24s${X} ${BD}#%-4s${X} %s ${DIM}(@%s)${X}\n" "$repo" "$num" "$title" "$author"; n=$((n+1))
  done < <(printf '%s\n' "$rows")
  [ "$n" -eq 0 ] && printf "  ${G}✓ nothing open${X}\n"
  printf "\n  ${BD}%d open${X}  ${DIM}· view one:  gh pr view <n> -R %s/<repo>${X}\n\n" "$n" "$OWNER"
}

# ── new (scaffold a repo to standard) ─────────────────────────────────────
cmd_new(){
  is_help "${1:-}" && { help_new; return 0; }
  need_owner || return 1
  local name="" vis="--private" desc="" scope="" dry=0
  while [ $# -gt 0 ]; do case "$1" in
    --public) vis="--public";; --private) vis="--private";;
    --desc) shift; desc="${1:-}";; --scope) shift; scope="${1:-}";;
    --dry-run|-n) dry=1;; -*) printf "  ${Y}ignoring unknown option: %s${X}\n" "$1";;
    *) name="$1";;
  esac; shift; done
  [ -z "$name" ] && { printf "  ${R}usage:${X} huginn new <name> [--public] [--desc \"…\"] [--scope web|k8s|infra] [--dry-run]\n"; return 1; }
  local DIR="$ROOT/$name" RC="$CONV" ag_cfg ag_wf ruleset apply src
  [ -e "$DIR" ] && { printf "  ${R}✗ %s already exists locally${X}\n" "$DIR"; return 1; }
  gh repo view "$OWNER/$name" >/dev/null 2>&1 && { printf "  ${R}✗ %s/%s already exists on GitHub${X}\n" "$OWNER" "$name"; return 1; }
  ag_cfg="$(first_of "$RC/.agentgate.yml" "$HERE/templates/agentgate-config.yml")"
  ag_wf="$(first_of "$RC/.github/workflows/agentgate.yml" "$HERE/templates/agentgate-workflow.yml")"
  ruleset="$(first_of "$RC/ruleset.json" "$HERE/templates/ruleset.json")"
  apply="$(first_of "$RC/apply-conventions.sh" "$HERE/templates/apply-conventions.sh")"
  [ -d "$RC" ] && src="$RC" || src="bundled templates"

  printf "\n  ${BD}huginn new${X} ${DIM}· scaffold '%s'${X}\n\n" "$name"
  printf "    owner       %s\n" "$OWNER"
  printf "    visibility  %s\n" "${vis#--}"
  printf "    guardrails  .agentgate.yml · workflow · ruleset · labels%s ${DIM}(from %s)${X}\n" "$([ -n "$scope" ] && echo " + $scope")" "$src"
  printf "    docs        README · LICENSE · CHANGELOG · ROADMAP · CONTRIBUTING\n"
  [ -n "$desc" ] && printf "    description %s\n" "$desc"
  if [ "$dry" = 1 ]; then printf "\n  ${DIM}[dry-run] nothing created — drop --dry-run to build it.${X}\n\n"; return 0; fi

  printf "\n"
  mkdir -p "$DIR/.github/workflows"
  [ -n "$ag_cfg" ] && cp "$ag_cfg" "$DIR/.agentgate.yml"
  [ -n "$ag_wf" ]  && cp "$ag_wf"  "$DIR/.github/workflows/agentgate.yml"
  printf '.DS_Store\n*.log\n' > "$DIR/.gitignore"
  printf 'MIT License\n\nCopyright (c) %s %s\n' "$(date +%Y)" "$BIZ_NAME" > "$DIR/LICENSE"
  cat > "$DIR/CONTRIBUTING.md" <<'CONTRIB'
# Contributing

- **No direct commits to `main`** — branch → PR → green checks → merge.
- **AgentGate runs on every PR** (if configured) — `secrets` + `dangerous_patterns` block.
- Never commit secrets (`.env`, keys are gitignored).
CONTRIB
  printf '# %s\n\n%s\n' "$name" "${desc:-_TODO: describe this project._}" > "$DIR/README.md"
  cat > "$DIR/CHANGELOG.md" <<CHLOG
# Changelog

All notable changes to $name are documented here. The format is based on
[Keep a Changelog](https://keepachangelog.com/en/1.1.0/), and this project adheres to
[Semantic Versioning](https://semver.org/spec/v2.0.0.html).

## [Unreleased]

### Added
- Initial scaffold.
CHLOG
  cat > "$DIR/ROADMAP.md" <<RDMAP
# Roadmap

_What's planned for $name — check items off as they ship._

## Next
- [ ] Define the first milestone.
RDMAP

  git -C "$DIR" init -q
  git -C "$DIR" config user.email "$BIZ_EMAIL"; git -C "$DIR" config user.name "$BIZ_NAME"
  git -C "$DIR" add .
  git -C "$DIR" commit -q -m "chore: initial scaffold" && printf "  ${G}✓${X} genesis commit\n"
  if ( cd "$DIR" && gh repo create "$OWNER/$name" $vis --source=. --remote=origin --push ) >/dev/null 2>&1; then
    printf "  ${G}✓${X} created + pushed %s/%s ${DIM}(%s)${X}\n" "$OWNER" "$name" "${vis#--}"
  else printf "  ${R}✗ gh repo create failed${X}\n"; return 1; fi
  [ -n "$desc" ] && gh repo edit "$OWNER/$name" --description "$desc" >/dev/null 2>&1
  [ -n "$ruleset" ] && gh api -X POST "repos/$OWNER/$name/rulesets" --input "$ruleset" >/dev/null 2>&1 && printf "  ${G}✓${X} ruleset applied\n"
  [ -n "$apply" ] && bash "$apply" "$OWNER/$name" "$scope" >/dev/null 2>&1 && printf "  ${G}✓${X} labels applied\n"
  printf "\n  ${BD}%s${X} → ${C}https://github.com/%s/%s${X}\n\n" "$name" "$OWNER" "$name"
}

# ── open (jump to a repo on GitHub) ───────────────────────────────────────
open_url(){
  local url="$1" o
  for o in wslview xdg-open open; do command -v "$o" >/dev/null 2>&1 && { "$o" "$url" >/dev/null 2>&1 & return 0; }; done
  command -v explorer.exe >/dev/null 2>&1 && { explorer.exe "$url" >/dev/null 2>&1 & return 0; }
  printf "  ${DIM}(no browser opener found — visit it yourself)${X}\n"
}
cmd_open(){
  is_help "${1:-}" && { help_open; return 0; }
  need_owner || return 1
  local repo="${1:-}" page="${2:-}" base url
  [ -z "$repo" ] && { printf "  ${R}usage:${X} huginn open <repo> [pr|settings|rules|security|actions|issues]\n"; return 1; }
  base="https://github.com/$OWNER/$repo"
  case "$page" in
    ""|home)            url="$base";;
    pr|prs|pulls)       url="$base/pulls";;
    settings|set)       url="$base/settings";;
    rules|ruleset)      url="$base/settings/rules";;
    security|sec)       url="$base/settings/security_analysis";;
    actions|ci)         url="$base/actions";;
    issues)             url="$base/issues";;
    *)                  url="$base/$page";;
  esac
  printf "  ${DIM}opening${X} ${C}%s${X}\n" "$url"
  open_url "$url"
}

# ── branches (surface / prune stray local branches) ───────────────────────
cmd_branches(){
  is_help "${1:-}" && { help_branches; return 0; }
  local PRUNE=0; [ "${1:-}" = "--prune" ] && PRUNE=1
  printf "\n  ${BD}huginn branches${X}%s\n\n" "$([ "$PRUNE" = 1 ] && echo "  ${DIM}· deleting merged local branches${X}")"
  local total=0 pruned=0
  while read -r d; do
    is_exempt "$d" && continue
    local GD="$ROOT/$d" def cur extras mergedset
    def=$(git -C "$GD" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##'); def=${def:-main}
    cur=$(git -C "$GD" symbolic-ref --short HEAD 2>/dev/null)
    extras=$(git -C "$GD" for-each-ref --format='%(refname:short)' refs/heads 2>/dev/null | grep -vx "$def" || true)
    [ -z "$extras" ] && continue
    total=$((total+1))
    mergedset=$(git -C "$GD" for-each-ref --format='%(refname:short)' --merged "$def" refs/heads 2>/dev/null)
    printf "  ${BD}%s${X} ${DIM}(default: %s)${X}\n" "$d" "$def"
    while read -r b; do
      [ -z "$b" ] && continue
      if grep -qx "$b" <<<"$mergedset"; then
        if [ "$PRUNE" = 1 ] && [ "$b" != "$cur" ]; then
          git -C "$GD" branch -d "$b" >/dev/null 2>&1 && { printf "    ${G}✓ deleted${X} %s\n" "$b"; pruned=$((pruned+1)); } || printf "    ${Y}∙ %s (merged, couldn't delete)${X}\n" "$b"
        else printf "    ${DIM}∙${X} %s ${G}(merged)${X}%s\n" "$b" "$([ "$b" = "$cur" ] && echo " ${Y}[current]${X}")"; fi
      else printf "    ${DIM}∙${X} %s ${Y}(unmerged)${X}\n" "$b"; fi
    done <<< "$extras"
  done < <(repos)
  [ "$total" -eq 0 ] && printf "  ${G}✓ no stray local branches anywhere${X}\n"
  if [ "$PRUNE" = 1 ]; then printf "\n  ${BD}%d merged branches deleted${X}\n\n" "$pruned"
  else printf "\n  ${DIM}%d repos have extra local branches · 'huginn branches --prune' deletes the merged ones${X}\n\n" "$total"; fi
}

# ── init (write a config file) ────────────────────────────────────────────
cmd_init(){
  is_help "${1:-}" && { help_init; return 0; }
  local force=0; [ "${1:-}" = "--force" ] && force=1
  mkdir -p "$(dirname "$CONFIG")"
  if [ -f "$CONFIG" ] && [ "$force" = 0 ]; then
    printf "\n  config already exists → ${C}%s${X}\n  ${DIM}edit it directly, or 'huginn init --force' to overwrite.${X}\n\n" "$CONFIG"; return 0
  fi
  local o e n; o="$(gh api user --jq .login 2>/dev/null)"; e="$(git config user.email 2>/dev/null)"; n="$(git config user.name 2>/dev/null)"
  cat > "$CONFIG" <<CFG
# huginn configuration — https://github.com/brett-buskirk/huginn
HUGINN_OWNER="$o"
HUGINN_EMAIL="$e"
HUGINN_NAME="$n"
HUGINN_ROOT="\$HOME/github-repos"
HUGINN_FAMILY=""                       # space-separated repos to exclude from sync/doctor
HUGINN_CONVENTIONS="repo-conventions"  # dir under HUGINN_ROOT with labels.json/ruleset.json
CFG
  printf "\n  ${G}✓${X} wrote ${C}%s${X}\n\n" "$CONFIG"
  sed 's/^/    /' "$CONFIG"
  printf "\n  ${DIM}edit as needed — env vars (HUGINN_*) override the file.${X}\n\n"
}
help_init(){
  printf "\n  ${BD}huginn init${X} [--force]\n\n"
  printf "  Write a config file (${DIM}%s${X}) with detected defaults —\n" "$CONFIG"
  printf "  your GitHub login, git email/name, and estate paths. Edit it afterward.\n\n"
  printf "  ${BD}Config keys${X} ${DIM}(an env HUGINN_* var overrides the file)${X}\n"
  printf "    HUGINN_OWNER · HUGINN_EMAIL · HUGINN_NAME · HUGINN_ROOT · HUGINN_FAMILY · HUGINN_CONVENTIONS\n\n"
}

# ── per-command help ──────────────────────────────────────────────────────
help_status(){
  printf "\n  ${BD}huginn status${X} [--fetch] [--public | --private]\n\n"
  printf "  At-a-glance dashboard of every git repo in the estate. Fast & local by default.\n\n"
  printf "  ${BD}Columns${X}\n"
  printf "    REPO      repo (local folder) name\n"
  printf "    BRANCH    current branch  ${DIM}(${X}${G}green${X}${DIM}=default, ${X}${C}cyan${X}${DIM}=feature)${X}\n"
  printf "    LAST      time since the last commit\n"
  printf "    STATUS    ✓ clean · ● N changed · ↑ahead ↓behind · ⚑N stashes ·\n"
  printf "              +N br (extra local branches) · ✉? no local email ·\n"
  printf "              ✉ <addr> (local email ≠ business address)\n\n"
  printf "  ${BD}Options${X}\n"
  printf "    -f, --fetch   git fetch each repo first for fresh ahead/behind ${DIM}(network)${X}\n"
  printf "    --public      only public repos  ${DIM}(network — reads visibility via gh)${X}\n"
  printf "    --private     only private repos ${DIM}(network)${X}\n\n"
}
help_sync(){
  printf "\n  ${BD}huginn sync${X}\n\n"
  printf "  Pull every repo to its default branch — fast-forward only.\n\n"
  printf "  For each: checkout the default branch, then ${BD}git pull --ff-only${X}.\n"
  printf "  ${BD}Skips${X} repos with uncommitted changes (won't clobber work) and\n"
  printf "  exempt repos (\$HUGINN_FAMILY + exemptions.json). ${DIM}Never force-pulls or merges — a repo that can't fast-forward\n"
  printf "  is reported, not touched. Summarizes updated / skipped / problems.${X}\n\n"
}
help_doctor(){
  printf "\n  ${BD}huginn doctor${X} [repo] [--fix] [-v]\n\n"
  printf "  Audit repos against your conventions; surface only what's off.\n\n"
  printf "  ${BD}Checks${X}\n"
  printf "    Baseline (all):       local user.email = business address · ruleset present\n"
  printf "    Managed (AG-wired):   + agentgate required · signed commits required ·\n"
  printf "                          .agentgate.yml present · secret scanning on (public) ·\n"
  printf "                          required doc suite present (README/LICENSE/CHANGELOG/ROADMAP/CONTRIBUTING) ·\n"
  printf "                          no leftover classic branch protection (estate standard is rulesets)\n"
  printf "    ${DIM}Dormant/unwired repos get the baseline only; exempt repos are skipped.${X}\n\n"
  printf "  ${BD}Arguments${X}\n"
  printf "    repo            audit a single repo (fast) instead of the whole estate\n\n"
  printf "  ${BD}Options${X}\n"
  printf "    --fix           auto-fix the safe gaps: set business email, and re-apply the\n"
  printf "                    standard ruleset on any managed repo where it's missing/drifted\n"
  printf "    -v, --verbose   also list repos that pass ${DIM}(default: only gaps)${X}\n\n"
  printf "  ${DIM}Network — reads each repo's ruleset + security settings; a full sweep\n"
  printf "  takes a minute or two.${X}\n\n"
}
help_apply(){
  printf "\n  ${BD}huginn apply${X} <owner/repo> <scope>\n\n"
  printf "  Apply the canonical label taxonomy to a repo ${DIM}(idempotent; delegates to\n"
  printf "  apply-conventions.sh — your conventions repo's, or the bundled one)${X}.\n\n"
  printf "  ${BD}Arguments${X}\n"
  printf "    <owner/repo>    e.g. youruser/website\n"
  printf "    <scope>         web | k8s | infra  ${DIM}(domain labels on top of the base set)${X}\n\n"
  printf "  ${BD}Example${X}\n"
  printf "    huginn apply youruser/website web\n\n"
  printf "  ${DIM}Labels only. Ruleset, git identity, metadata, milestones, and the board are\n"
  printf "  separate steps — see 'huginn conventions doc'.${X}\n\n"
}
help_conventions(){
  printf "\n  ${BD}huginn conventions${X} [labels [scope] | ruleset | doc]\n\n"
  printf "  Look up the standard you apply and are audited against — your ${BD}HUGINN_CONVENTIONS${X}\n"
