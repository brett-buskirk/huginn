  printf "  author). Excludes exempt repos (\$HUGINN_FAMILY + exemptions.json). Handy for \"what's in flight / needs a\n"
  printf "  merge?\" after agents have been working. ${DIM}(network — one search query)${X}\n\n"
}
help_new(){
  printf "\n  ${BD}huginn new${X} <name> [--public] [--desc \"…\"] [--scope web|k8s|infra] [--dry-run]\n\n"
  printf "  Scaffold a brand-new repo to the full standard, end to end:\n"
  printf "    git init · local business email · guardrail files (.agentgate.yml + workflow) ·\n"
  printf "    README · LICENSE · CHANGELOG · ROADMAP · CONTRIBUTING · .gitignore · signed genesis commit ·\n"
  printf "    private GitHub repo · ruleset (PR + agentgate + signatures) · base+scope labels.\n\n"
  printf "  ${BD}Options${X}\n"
  printf "    --public        create public (default: private)\n"
  printf "    --desc \"…\"       set the repo description\n"
  printf "    --scope <s>      also apply a label scope (web | k8s | infra)\n"
  printf "    --dry-run, -n   print the plan, create nothing\n\n"
  printf "  ${DIM}Example:  huginn new observatory --scope k8s --desc \"DOKS monitoring add-on\"${X}\n\n"
}
help_open(){
  printf "\n  ${BD}huginn open${X} <repo> [page]\n\n"
  printf "  Open a repo (or one of its pages) on GitHub in your browser.\n\n"
  printf "  ${BD}Pages${X}  ${DIM}(default: home)${X}\n"
  printf "    pr · settings · rules · security · actions · issues\n\n"
  printf "  ${DIM}Example:  huginn open website rules${X}\n\n"
}
help_branches(){
  printf "\n  ${BD}huginn branches${X} [--prune]\n\n"
  printf "  List every repo that has local branches beyond its default, marking each\n"
  printf "  ${G}(merged)${X} or ${Y}(unmerged)${X}. Excludes exempt repos (\$HUGINN_FAMILY + exemptions.json).\n\n"
  printf "  ${BD}Options${X}\n"
  printf "    --prune   delete the branches already merged into the default ${DIM}(safe: git branch -d,\n"
  printf "              never the current branch, never unmerged work)${X}\n\n"
}

# ── help ──────────────────────────────────────────────────────────────────
cmd_help(){
  printf "\n  ${BD}huginn${X} ${DIM}— estate CLI · %s${X}\n\n" "$ROOT"
  printf "  ${DIM}create${X}\n"
  printf "    ${BD}new${X} <name> [opts]      scaffold a new repo to the full standard\n"
  printf "    ${BD}init${X} [--force]         write a huginn config with detected defaults\n"
  printf "  ${DIM}inspect${X}\n"
  printf "    ${BD}status${X} [--fetch]       at-a-glance dashboard (branch · dirty · ahead/behind · flags)\n"
  printf "    ${DIM}       [--public|--private]  filter the dashboard by repo visibility${X}\n"
  printf "    ${BD}prs${X}                    open PRs across the estate\n"
  printf "    ${BD}branches${X} [--prune]     stray local branches; prune merged ones\n"
  printf "    ${BD}doctor${X} [repo] [--fix]  audit repos vs your conventions; --fix the safe gaps\n"
  printf "  ${DIM}operate${X}\n"
  printf "    ${BD}sync${X}                   pull every repo to its default branch (ff-only, skips dirty)\n"
  printf "    ${BD}apply${X} <repo> <scope>   apply the label taxonomy to a repo (web|k8s|infra)\n"
  printf "  ${DIM}reference / navigate${X}\n"
  printf "    ${BD}conventions${X} [topic]    look up the standard (labels · ruleset · suite · doc)\n"
  printf "    ${BD}open${X} <repo> [page]     open a repo (or prs/settings/rules) on GitHub\n"
  printf "    ${BD}help${X}                   this menu\n\n"
  printf "  ${DIM}run${X} ${BD}huginn <command> help${X} ${DIM}for details & options on any command.${X}\n\n"
}

case "${1:-help}" in
  status) shift; cmd_status "$@";;
  sync)   shift; cmd_sync "$@";;
  doctor) shift; cmd_doctor "$@";;
  apply)  shift; cmd_apply "$@";;
  conventions|conv|std) shift; cmd_conventions "$@";;
  prs)    shift; cmd_prs "$@";;
  new)    shift; cmd_new "$@";;
  init)   shift; cmd_init "$@";;
  open)   shift; cmd_open "$@";;
  branches|br) shift; cmd_branches "$@";;
  help|-h|--help) cmd_help;;
  *) printf "${R}unknown command: %s${X}\n" "$1"; cmd_help; exit 1;;
esac
